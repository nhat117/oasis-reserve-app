# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_TENANT_ID=your-tenant-uuid

# Web Push (optional) — generate with `npx web-push generate-vapid-keys`.
# The public key goes here; the private key is a Supabase Edge Function
# secret (VAPID_PRIVATE_KEY), never in frontend env.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
